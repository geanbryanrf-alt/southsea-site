# TODO: VALIDAR COM O CLIENTE ANTES DA PUBLICAÇÃO.
# Chave de API do Resend (https://resend.com) usada para enviar as solicitações
# do formulário de análise estratégica por e-mail. Sem essa chave, o formulário
# informa que o canal ainda não está disponível e orienta o uso do WhatsApp.
RESEND_API_KEY=

# E-mail que deve receber as notificações de novas solicitações.
SOUTHSEA_NOTIFICATION_EMAIL=

# Remetente usado no envio (precisa de domínio verificado no Resend para produção;
# "onboarding@resend.dev" funciona apenas para testes).
SOUTHSEA_NOTIFICATION_FROM="Southsea Investments <onboarding@resend.dev>"

# Domínio público definitivo usado em canonical, sitemap e dados estruturados.
NEXT_PUBLIC_SITE_URL=https://southseainvestments.com.br